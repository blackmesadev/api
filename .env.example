# Required
DATABASE_URL=postgresql://mesa:changeme@localhost:5432/blackmesa
REDIS_URI=redis://localhost:6379
DISCORD_CLIENT_ID=YOUR_DISCORD_CLIENT_ID_HERE
DISCORD_CLIENT_SECRET=YOUR_DISCORD_CLIENT_SECRET_HERE
DISCORD_REDIRECT_URI=http://localhost:8080/auth/callback
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# Optional
API_HOST=0.0.0.0
API_PORT=8080
REDIS_PREFIX=bm-api
BOT_REDIS_PREFIX=black-mesa
OTLP_ENDPOINT=http://openobserve:5081
OTLP_AUTH="Basic your_base64_encoded_auth_token"
OTLP_ORGANIZATION=black-mesa
RUST_LOG=info
